# ==============================================
# BAGLO BACKEND ENVIRONMENT CONFIG
# ==============================================

# Server
PORT=3001

# Stacks Network
STACKS_NETWORK=testnet
STACKS_API_URL=https://api.testnet.hiro.so

# Deployed Contract Addresses (update after clarinet deploy --testnet)
CONTRACT_ADDRESS=ST_YOUR_DEPLOYER_ADDRESS
CONTRACT_NAME=baglo-core
TOKEN_CONTRACT_ADDRESS=ST_YOUR_DEPLOYER_ADDRESS
TOKEN_CONTRACT_NAME=mock-usdcx

# Admin Private Key (the key that can confirm deposits/withdrawals on-chain)
# Generate with: npx @stacks/cli make_keychain -t
ADMIN_PRIVATE_KEY=your_testnet_private_key_hex

# Flutterwave API Keys (from dashboard.flutterwave.com)
FLW_PUBLIC_KEY=FLWPUBK-xxxxxxx
FLW_SECRET_KEY=FLWSECK-xxxxxxx
FLW_ENCRYPTION_KEY=xxxxxxx
FLW_WEBHOOK_SECRET=your_webhook_hash

# MongoDB (free tier at mongodb.com/cloud/atlas)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/baglo?retryWrites=true

# Default exchange rates (MVP - replace with real API later)
DEFAULT_NGN_RATE=1500
DEFAULT_GBP_RATE=0.79
